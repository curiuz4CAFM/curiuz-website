# dependencies
/node_modules
/.pnp
.pnp.js

# next.js
/.next/
/out/
/build
next-env.d.ts

# production / vercel
/.vercel
*.tsbuildinfo

# env files (keep .env.local.example tracked)
.env
.env*.local

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# os / editor
.DS_Store
*.pem
Thumbs.db

# lib/ holds local-only source assets (videos, logo packs, zips).
# Only site-data.ts is needed at build time — ignore everything else.
/lib/*
!/lib/site-data.ts
